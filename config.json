{
    "port": 3002,
    "collection_interval_seconds": 30,
    "theforge_db_path": "/srv/forge-share/AI_Stuff/TheForge/theforge.db",
    "hosts": [
        {
            "name": "claudinator",
            "type": "local"
        },
        {
            "name": "cryptotrader-vm",
            "type": "ssh",
            "ssh_host": "10.10.10.2",
            "ssh_user": "user",
            "ssh_key_path": "/home/user/.ssh/id_ed25519"
        }
    ],
    "default_alerts": [
        {
            "metric": "disk_percent",
            "operator": ">",
            "threshold": 90,
            "severity": "critical"
        },
        {
            "metric": "memory_percent",
            "operator": ">",
            "threshold": 85,
            "severity": "warning"
        },
        {
            "metric": "cpu_percent",
            "operator": ">",
            "threshold": 95,
            "severity": "warning"
        },
        {
            "metric": "backup_stale",
            "operator": ">",
            "threshold": 24,
            "severity": "warning"
        },
        {
            "metric": "service_down",
            "operator": "==",
            "threshold": 0,
            "severity": "critical"
        },
        {
            "metric": "container_down",
            "operator": "==",
            "threshold": 0,
            "severity": "critical"
        }
    ],
    "retention": {
        "metrics_full_days": 7,
        "metrics_downsampled_days": 30,
        "containers_days": 7,
        "alert_history_days": 90
    },
    "backups": [
        {
            "name": "local-restic",
            "type": "restic",
            "description": "Local backups to Gort external drive",
            "repo_path": "sftp:root@192.168.0.22:/mnt/backup/claudinator-backups",
            "password_file": "/home/user/.restic-password",
            "stale_hours": 26
        },
        {
            "name": "offsite-linode",
            "type": "restic",
            "description": "Offsite backups to Linode via SFTP",
            "repo_path": "sftp:root@45.79.183.67:/backups/claudinator",
            "password_file": "/home/user/.restic-password",
            "stale_hours": 26
        }
    ],
    "recon": {
        "enabled": true,
        "gather_interval_hours": 6,
        "reddit": {
            "subreddits": [
                "MechanicAdvice",
                "AutoRepair",
                "AutoRepairShop",
                "mtg",
                "mtgfinance",
                "EDH",
                "magicTCG",
                "ethereum",
                "solana",
                "cryptocurrency"
            ],
            "keywords": [
                "Tekmetric",
                "Shopmonkey",
                "Shop-Ware",
                "Mitchell 1",
                "AutoLeap",
                "auto repair software",
                "shop management",
                "TCGplayer",
                "Moxfield",
                "Archidekt",
                "Delver Lens",
                "card scanning",
                "card grading",
                "LGS software",
                "Ethereum L2",
                "Solana",
                "DeFi"
            ],
            "max_posts_per_sub": 25
        },
        "news": {
            "rss_feeds": [
                "https://techcrunch.com/feed/",
                "https://www.coindesk.com/arc/outboundfeeds/rss/",
                "https://icv2.com/feed"
            ],
            "keywords": [
                "auto repair",
                "automotive software",
                "TCGplayer",
                "trading card",
                "card grading",
                "MTG",
                "Pokemon TCG",
                "blockchain",
                "cryptocurrency",
                "DeFi",
                "Ethereum",
                "Solana"
            ]
        },
        "industries": {
            "auto-repair": [
                "Tekmetric",
                "Shopmonkey",
                "Shop-Ware",
                "Mitchell 1",
                "AutoLeap",
                "auto repair",
                "shop management"
            ],
            "tcg": [
                "TCGplayer",
                "Moxfield",
                "Archidekt",
                "Delver Lens",
                "MTG",
                "Pokemon",
                "card grading",
                "LGS"
            ],
            "blockchain": [
                "Ethereum",
                "Solana",
                "DeFi",
                "cryptocurrency",
                "blockchain",
                "crypto"
            ]
        }
    }
}